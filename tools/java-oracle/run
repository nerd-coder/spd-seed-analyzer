#!/usr/bin/env bash

set -euo pipefail

readonly EXPECTED_COMMIT="7b8b845a76fe76c6b7c031ae9e570852411f56db"
readonly DEFAULT_SOURCE="/Users/toan/code/repos/00-Evan/shattered-pixel-dungeon"

tool_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source_dir="${SPD_SOURCE:-$DEFAULT_SOURCE}"
output_path=""
depth=""
final_heaps_depth=""

usage() {
	cat >&2 <<'EOF'
Usage: tools/java-oracle/run [--source PATH] [--output FILE]
                             [--depth 1 | --final-heaps-depth 1|6|8] SEED

Dumps SPD v3.3.8 run facts as stable JSON. With --depth 1, includes the pinned
depth-one pre-build item slice. With --final-heaps-depth 1, 6, or 8, records
heaps after the real level generation lifecycle completes. Floors 6 and 8 are
generated after all prior floors to retain run-persistent state. The source checkout
must be pinned at 7b8b845a7.
EOF
}

while (($# > 0)); do
	case "$1" in
		--source)
			[[ $# -ge 2 ]] || { usage; exit 2; }
			source_dir="$2"
			shift 2
			;;
		--output)
			[[ $# -ge 2 ]] || { usage; exit 2; }
			output_path="$2"
			shift 2
			;;
		--depth)
			[[ $# -ge 2 ]] || { usage; exit 2; }
			depth="$2"
			shift 2
			;;
		--final-heaps-depth)
			[[ $# -ge 2 ]] || { usage; exit 2; }
			final_heaps_depth="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		--*)
			echo "Unknown option: $1" >&2
			usage
			exit 2
			;;
		*)
			break
			;;
	esac
done

[[ $# -eq 1 ]] || { usage; exit 2; }
seed="$1"
if [[ -n "$depth" && "$depth" != "1" ]]; then
	echo "The floor oracle currently supports only --depth 1" >&2
	exit 2
fi
if [[ -n "$final_heaps_depth" && "$final_heaps_depth" != "1" && "$final_heaps_depth" != "6" && "$final_heaps_depth" != "8" ]]; then
	echo "The final-heaps oracle currently supports only --final-heaps-depth 1, 6, or 8" >&2
	exit 2
fi
if [[ -n "$depth" && -n "$final_heaps_depth" ]]; then
	echo "--depth and --final-heaps-depth are separate contracts and cannot be combined" >&2
	exit 2
fi

for command_name in git java tar; do
	command -v "$command_name" >/dev/null || {
		echo "Required command not found: $command_name" >&2
		exit 1
	}
done

[[ -x "$source_dir/gradlew" ]] || {
	echo "Not an SPD checkout (gradlew is missing): $source_dir" >&2
	exit 1
}

actual_commit="$(git -C "$source_dir" rev-parse HEAD)"
if [[ "$actual_commit" != "$EXPECTED_COMMIT" ]]; then
	echo "SPD checkout is not at the supported pin." >&2
	echo "Expected: $EXPECTED_COMMIT" >&2
	echo "Actual:   $actual_commit" >&2
	exit 1
fi

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/spd-java-oracle.XXXXXX")"
cleanup() {
	rm -rf "$work_dir"
}
trap cleanup EXIT

snapshot_dir="$work_dir/spd"
mkdir -p "$snapshot_dir"
git -C "$source_dir" archive "$EXPECTED_COMMIT" | tar -x -C "$snapshot_dir"

gradle_args=(
	--no-daemon
	--console plain
	--quiet
	--configure-on-demand
	--init-script "$tool_dir/oracle.gradle"
	-PoracleSourceDir="$tool_dir/src"
	-PoracleSeed="$seed"
)

if [[ -n "$depth" ]]; then
	gradle_args+=(-PoracleDepth="$depth")
fi
if [[ -n "$final_heaps_depth" ]]; then
	gradle_args+=(-PoracleFinalHeapsDepth="$final_heaps_depth")
fi
gradle_args+=(:core:javaOracleDump)

if [[ -n "$output_path" ]]; then
	mkdir -p "$(dirname "$output_path")"
	temporary_output="$work_dir/oracle.json"
	"$snapshot_dir/gradlew" -p "$snapshot_dir" "${gradle_args[@]}" >"$temporary_output"
	mv "$temporary_output" "$output_path"
else
	"$snapshot_dir/gradlew" -p "$snapshot_dir" "${gradle_args[@]}"
fi
